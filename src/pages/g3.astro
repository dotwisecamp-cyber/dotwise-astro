---
// src/pages/g3.astro
import Layout from '../components/Layout.astro';
---

<Layout title="dotwise G3 RGB — Multi-Use LED Lantern | 8 Colors · 4 Modes">

    <!-- ============================================================ -->
    <!-- 产品主视觉 Hero -->
    <!-- ============================================================ -->
    <header class="hero-gradient pt-28 min-h-screen flex items-center relative overflow-hidden">
        <div class="absolute inset-0 opacity-5" style="background-image: url('data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSI2MCIgaGVpZ2h0PSI2MCIgdmlld0JveD0iMCAwIDYwIDYwIj48cGF0aCBkPSJNMzAgNWwxMC4zIDUuN2wxMC4zIDUuN3YxMS4zbC0xMC4zIDUuN0wzMCAzNWwtMTAuMy01LjdMOS4zIDE3LjdWNi40TDE5LjcgNS43IDMwIDV6IiBmaWxsPSIjZmZmIiBvcGFjaXR5PSIwLjA1Ii8+PC9zdmc+'); background-size: 60px 60px;"></div>

        <div class="max-w-7xl mx-auto px-4 sm:px-6 relative z-10 py-16">
            <div class="grid lg:grid-cols-2 gap-12 items-center">

                <!-- 左侧文案 -->
                <div>
                    <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm text-white/90 text-xs sm:text-sm px-4 py-1.5 rounded-full mb-6 tracking-wide">
                        <span class="w-2 h-2 bg-[#c9a96e] rounded-full animate-pulse"></span>
                        NEW · 2026 Collection
                    </div>

                    <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold text-white leading-[1.1] tracking-tight">
                        dotwise G3 RGB
                        <span class="block text-[#e8d5b5] mt-1">Multi-Use LED Lantern</span>
                    </h1>

                    <p class="text-white/75 text-lg md:text-xl max-w-lg mt-6 leading-relaxed">
                        360° illumination, 8 color modes, 4 lighting modes, and 3000mAh battery — the ultimate companion for camping, emergencies, and everyday adventures.
                    </p>

                    <div class="flex flex-wrap gap-3 mt-8">
                        <span class="bg-white/10 backdrop-blur-sm text-white/90 text-sm px-4 py-2 rounded-full border border-white/10">💡 200LM</span>
                        <span class="bg-white/10 backdrop-blur-sm text-white/90 text-sm px-4 py-2 rounded-full border border-white/10">🔋 3000mAh</span>
                        <span class="bg-white/10 backdrop-blur-sm text-white/90 text-sm px-4 py-2 rounded-full border border-white/10">⚡ Type-C</span>
                        <span class="bg-white/10 backdrop-blur-sm text-white/90 text-sm px-4 py-2 rounded-full border border-white/10">🌧️ IPX4</span>
                    </div>

                    <div class="flex flex-wrap gap-4 mt-10">
                        <a href="#specs" class="bg-[#e8d5b5] hover:bg-[#dcc6a3] text-[#1a2a1a] px-8 py-3.5 rounded-full font-semibold transition shadow-lg flex items-center gap-2">
                            📋 View Specs
                        </a>
                        <a href="#features" class="border border-white/30 hover:bg-white/10 text-white px-8 py-3.5 rounded-full font-semibold transition flex items-center gap-2">
                            ✨ Features
                        </a>
                    </div>
                </div>

                <!-- 右侧产品图 -->
                <div class="relative flex justify-center lg:justify-end">
                    <div class="relative w-full max-w-sm lg:max-w-md">
                        <div class="aspect-square bg-gradient-to-br from-[#e8d5b5]/20 to-[#2d5a27]/20 rounded-3xl border border-white/10 backdrop-blur-sm flex items-center justify-center overflow-hidden">
                            <img src="https://img.dotwise.top/dotwiseg3baidi.jpg" alt="dotwise G3 RGB Multi-Use LED Lantern" class="w-full h-full object-cover rounded-3xl" />
                        </div>
                        <div class="absolute -bottom-4 -right-4 bg-white/10 backdrop-blur-md rounded-2xl px-5 py-3 border border-white/10 text-white text-sm font-medium">
                            <span class="text-[#e8d5b5]">✦</span> 8 Colors · 4 Modes
                        </div>
                        <div class="absolute -top-4 -left-4 bg-[#e8d5b5]/20 backdrop-blur-md rounded-2xl px-5 py-3 border border-white/10 text-white/90 text-sm font-medium">
                            <span class="text-[#e8d5b5]">⚡</span> 100h Runtime
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </header>

    <!-- ============================================================ -->
    <!-- 核心卖点 -->
    <!-- ============================================================ -->
    <section class="py-20 px-4 max-w-7xl mx-auto">
        <div class="text-center mb-16">
            <span class="inline-block bg-[#2d5a27]/10 text-[#2d5a27] text-xs font-semibold px-4 py-1 rounded-full tracking-wider uppercase mb-3">Why G3 RGB</span>
            <h2 class="text-3xl sm:text-4xl font-bold text-[#1a2a1a]">Designed for Every Moment</h2>
            <p class="text-gray-500 mt-3 max-w-xl mx-auto">From campsites to blackouts — G3 RGB is ready when you are.</p>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
            <div class="text-center p-6 rounded-2xl bg-white border border-gray-100 hover:shadow-lg transition">
                <div class="text-4xl mb-3">💡</div>
                <h3 class="font-bold text-[#1a2a1a]">360° Illumination</h3>
                <p class="text-gray-500 text-sm mt-2">Full-circle brightness lights up your entire surroundings.</p>
            </div>
            <div class="text-center p-6 rounded-2xl bg-white border border-gray-100 hover:shadow-lg transition">
                <div class="text-4xl mb-3">🎨</div>
                <h3 class="font-bold text-[#1a2a1a]">8 Color Modes</h3>
                <p class="text-gray-500 text-sm mt-2">Red, green, blue, purple, cyan, and rainbow flow.</p>
            </div>
            <div class="text-center p-6 rounded-2xl bg-white border border-gray-100 hover:shadow-lg transition">
                <div class="text-4xl mb-3">🔄</div>
                <h3 class="font-bold text-[#1a2a1a]">4 Lighting Modes</h3>
                <p class="text-gray-500 text-sm mt-2">Flashlight · Camp · Eco · SOS — one button to switch.</p>
            </div>
            <div class="text-center p-6 rounded-2xl bg-white border border-gray-100 hover:shadow-lg transition">
                <div class="text-4xl mb-3">🔋</div>
                <h3 class="font-bold text-[#1a2a1a]">100h Runtime</h3>
                <p class="text-gray-500 text-sm mt-2">3000mAh battery powers you through the longest nights.</p>
            </div>
        </div>
    </section>

    <!-- ============================================================ -->
    <!-- 功能详解 -->
    <!-- ============================================================ -->
    <section id="features" class="py-20 px-4 bg-[#f5f0e8]">
        <div class="max-w-6xl mx-auto">
            <div class="text-center mb-16">
                <span class="inline-block bg-[#2d5a27]/10 text-[#2d5a27] text-xs font-semibold px-4 py-1 rounded-full tracking-wider uppercase mb-3">How to Use</span>
                <h2 class="text-3xl sm:text-4xl font-bold text-[#1a2a1a]">Lighting Modes & Controls</h2>
                <p class="text-gray-500 mt-3 max-w-xl mx-auto">Simple, intuitive, and versatile.</p>
            </div>

            <div class="grid md:grid-cols-2 gap-12 items-center">
                <div>
                    <img src="https://img.dotwise.top/dotwiseg3baidi.jpg" alt="dotwise G3 RGB controls" class="rounded-3xl shadow-xl w-full object-cover" />
                </div>
                <div>
                    <div class="space-y-6">
                        <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100">
                            <h3 class="text-xl font-bold text-[#1a2a1a] flex items-center gap-2">🔄 Lighting Mode Switch</h3>
                            <p class="text-gray-600 mt-2">Short press the button to cycle through 4 lighting modes: <strong>Flashlight · Camp · Eco · SOS</strong>.</p>
                        </div>
                        <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100">
                            <h3 class="text-xl font-bold text-[#1a2a1a] flex items-center gap-2">🎚️ Stepless Dimming</h3>
                            <p class="text-gray-600 mt-2">In any lighting mode, <strong>long press</strong> to smoothly adjust brightness from 0 to 100%.</p>
                        </div>
                        <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100">
                            <h3 class="text-xl font-bold text-[#1a2a1a] flex items-center gap-2">🎨 8 Color Modes</h3>
                            <p class="text-gray-600 mt-2"><strong>Double-click</strong> to enter color mode. Each press cycles through: Red · Green · Blue · Yellow-Green · Purple · Cyan · Auto-Fade · Rainbow Flow.</p>
                        </div>
                        <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100">
                            <h3 class="text-xl font-bold text-[#1a2a1a] flex items-center gap-2">🔋 Battery Status</h3>
                            <p class="text-gray-600 mt-2">LED indicator shows remaining battery life at a glance — always know when to recharge.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ============================================================ -->
    <!-- 产品规格 -->
    <!-- ============================================================ -->
    <section id="specs" class="py-20 px-4 max-w-6xl mx-auto">
        <div class="text-center mb-16">
            <span class="inline-block bg-[#2d5a27]/10 text-[#2d5a27] text-xs font-semibold px-4 py-1 rounded-full tracking-wider uppercase mb-3">Specifications</span>
            <h2 class="text-3xl sm:text-4xl font-bold text-[#1a2a1a]">Product Details</h2>
            <p class="text-gray-500 mt-3">Everything you need to know about the G3 RGB.</p>
        </div>

        <div class="grid md:grid-cols-2 gap-8">
            <div class="bg-white rounded-3xl shadow-sm border border-gray-100 p-8">
                <div class="grid grid-cols-2 gap-4">
                    <div class="border-b border-gray-100 pb-3">
                        <p class="text-xs text-gray-400 font-medium uppercase tracking-wider">Dimensions</p>
                        <p class="text-sm font-semibold text-[#1a2a1a]">95 × 38 mm</p>
                    </div>
                    <div class="border-b border-gray-100 pb-3">
                        <p class="text-xs text-gray-400 font-medium uppercase tracking-wider">Weight</p>
                        <p class="text-sm font-semibold text-[#1a2a1a]">82 g</p>
                    </div>
                    <div class="border-b border-gray-100 pb-3">
                        <p class="text-xs text-gray-400 font-medium uppercase tracking-wider">Material</p>
                        <p class="text-sm font-semibold text-[#1a2a1a]">ABS + PC</p>
                    </div>
                    <div class="border-b border-gray-100 pb-3">
                        <p class="text-xs text-gray-400 font-medium uppercase tracking-wider">Battery</p>
                        <p class="text-sm font-semibold text-[#1a2a1a]">3.7V · 3000mAh</p>
                    </div>
                    <div class="border-b border-gray-100 pb-3">
                        <p class="text-xs text-gray-400 font-medium uppercase tracking-wider">Battery Model</p>
                        <p class="text-sm font-semibold text-[#1a2a1a]">18650 (replaceable)</p>
                    </div>
                    <div class="border-b border-gray-100 pb-3">
                        <p class="text-xs text-gray-400 font-medium uppercase tracking-wider">Max Brightness</p>
                        <p class="text-sm font-semibold text-[#1a2a1a]">200 LM</p>
                    </div>
                    <div class="border-b border-gray-100 pb-3">
                        <p class="text-xs text-gray-400 font-medium uppercase tracking-wider">Power</p>
                        <p class="text-sm font-semibold text-[#1a2a1a]">1.5 W</p>
                    </div>
                    <div class="border-b border-gray-100 pb-3">
                        <p class="text-xs text-gray-400 font-medium uppercase tracking-wider">Charging Port</p>
                        <p class="text-sm font-semibold text-[#1a2a1a]">Type-C</p>
                    </div>
                    <div class="pb-3">
                        <p class="text-xs text-gray-400 font-medium uppercase tracking-wider">Runtime (Low)</p>
                        <p class="text-sm font-semibold text-[#1a2a1a]">Up to 100 hours</p>
                    </div>
                    <div class="pb-3">
                        <p class="text-xs text-gray-400 font-medium uppercase tracking-wider">Runtime (High)</p>
                        <p class="text-sm font-semibold text-[#1a2a1a]">Up to 12 hours</p>
                    </div>
                </div>
            </div>

            <div class="bg-white rounded-3xl shadow-sm border border-gray-100 p-8">
                <h3 class="text-lg font-bold text-[#1a2a1a] mb-4">💡 4 Lighting Modes</h3>
                <ul class="space-y-2 text-sm text-gray-600 mb-6">
                    <li class="flex items-center gap-2">🔦 <span><strong>Flashlight</strong> — focused beam for distance</span></li>
                    <li class="flex items-center gap-2">🏕️ <span><strong>Camp</strong> — 360° ambient light for the site</span></li>
                    <li class="flex items-center gap-2">🌿 <span><strong>Eco</strong> — single-side energy-saving mode</span></li>
                    <li class="flex items-center gap-2">🆘 <span><strong>SOS</strong> — emergency flash beacon</span></li>
                </ul>

                <h3 class="text-lg font-bold text-[#1a2a1a] mb-4 mt-6">🎨 8 Color Modes</h3>
                <ul class="space-y-2 text-sm text-gray-600">
                    <li class="flex items-center gap-2"><span class="w-4 h-4 rounded-full bg-red-500 border border-gray-200"></span> Red</li>
                    <li class="flex items-center gap-2"><span class="w-4 h-4 rounded-full bg-green-500 border border-gray-200"></span> Green</li>
                    <li class="flex items-center gap-2"><span class="w-4 h-4 rounded-full bg-blue-500 border border-gray-200"></span> Blue</li>
                    <li class="flex items-center gap-2"><span class="w-4 h-4 rounded-full bg-yellow-400 border border-gray-200"></span> Yellow-Green</li>
                    <li class="flex items-center gap-2"><span class="w-4 h-4 rounded-full bg-purple-500 border border-gray-200"></span> Purple</li>
                    <li class="flex items-center gap-2"><span class="w-4 h-4 rounded-full bg-cyan-400 border border-gray-200"></span> Cyan</li>
                    <li class="flex items-center gap-2">🌈 <span>Auto-Fade</span></li>
                    <li class="flex items-center gap-2">🌈 <span>Rainbow Flow</span></li>
                </ul>
            </div>
        </div>
    </section>

    <!-- ============================================================ -->
    <!-- 应用场景 -->
    <!-- ============================================================ -->
    <section class="py-20 px-4 bg-[#1a2a1a] text-white">
        <div class="max-w-6xl mx-auto text-center">
            <span class="inline-block bg-[#e8d5b5]/20 text-[#e8d5b5] text-xs font-semibold px-4 py-1 rounded-full tracking-wider uppercase mb-3">Use Cases</span>
            <h2 class="text-3xl sm:text-4xl font-bold">One Light, Endless Possibilities</h2>
            <p class="text-white/60 mt-3 max-w-xl mx-auto">From the campsite to the blackout — G3 RGB has you covered.</p>
            <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6 mt-12">
                <div class="bg-white/5 backdrop-blur-sm rounded-2xl p-6 border border-white/10">
                    <div class="text-4xl mb-3">🏕️</div>
                    <h4 class="font-bold">Camping</h4>
                    <p class="text-white/50 text-sm">360° light for your tent and campsite.</p>
                </div>
                <div class="bg-white/5 backdrop-blur-sm rounded-2xl p-6 border border-white/10">
                    <div class="text-4xl mb-3">⚡</div>
                    <h4 class="font-bold">Emergency</h4>
                    <p class="text-white/50 text-sm">SOS mode and long runtime for blackouts.</p>
                </div>
                <div class="bg-white/5 backdrop-blur-sm rounded-2xl p-6 border border-white/10">
                    <div class="text-4xl mb-3">🎨</div>
                    <h4 class="font-bold">Ambient Lighting</h4>
                    <p class="text-white/50 text-sm">8 color modes to set the perfect mood.</p>
                </div>
                <div class="bg-white/5 backdrop-blur-sm rounded-2xl p-6 border border-white/10">
                    <div class="text-4xl mb-3">🎒</div>
                    <h4 class="font-bold">Everyday Carry</h4>
                    <p class="text-white/50 text-sm">Compact 82g design fits in any bag.</p>
                </div>
            </div>
        </div>
    </section>

</Layout>