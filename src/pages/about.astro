---
// src/pages/about.astro
import Layout from '../components/Layout.astro';
---

<Layout title="About dotwise — Premium Camping Gear Brand">

  <!-- Hero 区域 -->
  <section class="pt-32 pb-20 px-4 bg-[#f5f0e8]">
    <div class="max-w-4xl mx-auto text-center">
      <span class="inline-block bg-[#2d5a27]/10 text-[#2d5a27] text-xs font-semibold px-4 py-1 rounded-full tracking-wider uppercase mb-4">About Us</span>
      <h1 class="text-4xl sm:text-5xl font-bold text-[#1a2a1a] leading-tight">
        野奢露营
        <span class="block text-[#2d5a27] mt-2">从 dotwise 开始</span>
      </h1>
      <p class="text-gray-600 text-lg mt-6 max-w-2xl mx-auto leading-relaxed">
        dotwise 是一个致力于为露营爱好者提供高品质装备的品牌。
        从智能照明到舒适充气床垫，我们相信科技与自然可以完美融合。
      </p>
    </div>
  </section>

  <!-- 品牌故事 -->
  <section class="py-20 px-4 max-w-6xl mx-auto">
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <div>
        <span class="inline-block bg-[#2d5a27]/10 text-[#2d5a27] text-xs font-semibold px-4 py-1 rounded-full tracking-wider uppercase mb-4">Our Story</span>
        <h2 class="text-3xl font-bold text-[#1a2a1a] mb-6">我们的故事</h2>
        <p class="text-gray-600 leading-relaxed mb-4">
          dotwise 创立于 2021 年，源于一次露营之旅。我们发现，
          好的装备能让人更专注地享受大自然的馈赠。
        </p>
        <p class="text-gray-600 leading-relaxed">
          今天我们为露营爱好者提供从智能露营灯到 IGT 桌椅的全套装备，
          让每一次户外探索都成为值得珍藏的回忆。
        </p>
      </div>
      <div class="bg-[#f5f0e8] rounded-3xl aspect-[4/3] flex items-center justify-center">
        <span class="text-8xl">🏕️</span>
      </div>
    </div>
  </section>

  <!-- 价值观 -->
  <section class="py-20 px-4 bg-[#1a2a1a] text-white">
    <div class="max-w-6xl mx-auto text-center">
      <h2 class="text-3xl font-bold mb-12">我们的价值观</h2>
      <div class="grid sm:grid-cols-3 gap-8">
        <div>
          <div class="text-4xl mb-4">🌿</div>
          <h3 class="font-bold text-lg">与自然共生</h3>
          <p class="text-white/60 text-sm mt-2">尊重自然，让装备服务于人而非征服自然</p>
        </div>
        <div>
          <div class="text-4xl mb-4">🔧</div>
          <h3 class="font-bold text-lg">匠心品质</h3>
          <p class="text-white/60 text-sm mt-2">每一件产品都经过精心设计和严格测试</p>
        </div>
        <div>
          <div class="text-4xl mb-4">🌏</div>
          <h3 class="font-bold text-lg">连接亚洲</h3>
          <p class="text-white/60 text-sm mt-2">深耕中日韩市场，建立露营者社区</p>
        </div>
      </div>
    </div>
  </section>

</Layout>