---
// src/pages/support.astro
import Layout from '../components/Layout.astro';
---

<Layout title="Support — dotwise Customer Service">

  <!-- Hero 区域 -->
  <section class="pt-32 pb-20 px-4 bg-[#f5f0e8]">
    <div class="max-w-4xl mx-auto text-center">
      <span class="inline-block bg-[#2d5a27]/10 text-[#2d5a27] text-xs font-semibold px-4 py-1 rounded-full tracking-wider uppercase mb-4">Support</span>
      <h1 class="text-4xl sm:text-5xl font-bold text-[#1a2a1a] leading-tight">
        我们在这里
        <span class="block text-[#2d5a27] mt-2">随时为你服务</span>
      </h1>
      <p class="text-gray-600 text-lg mt-6 max-w-2xl mx-auto leading-relaxed">
        有任何问题或建议？我们会在 24 小时内回复。
      </p>
    </div>
  </section>

  <!-- 联系方式 -->
  <section class="py-20 px-4 max-w-6xl mx-auto">
    <div class="grid md:grid-cols-3 gap-8">
      <div class="bg-white rounded-3xl p-8 shadow-sm border border-gray-100 text-center">
        <div class="text-4xl mb-4">📧</div>
        <h3 class="text-xl font-bold text-[#1a2a1a]">邮箱</h3>
        <p class="text-gray-500 text-sm mt-2">support@dotwise.top</p>
        <p class="text-gray-400 text-xs mt-1">我们会在 24 小时内回复</p>
      </div>
      <div class="bg-white rounded-3xl p-8 shadow-sm border border-gray-100 text-center">
        <div class="text-4xl mb-4">📱</div>
        <h3 class="text-xl font-bold text-[#1a2a1a]">社交媒体</h3>
        <p class="text-gray-500 text-sm mt-2">@dotwise_camping</p>
        <p class="text-gray-400 text-xs mt-1">Instagram · YouTube · 小红书</p>
      </div>
      <div class="bg-white rounded-3xl p-8 shadow-sm border border-gray-100 text-center">
        <div class="text-4xl mb-4">🕐</div>
        <h3 class="text-xl font-bold text-[#1a2a1a]">服务时间</h3>
        <p class="text-gray-500 text-sm mt-2">周一至周五 9:00–18:00</p>
        <p class="text-gray-400 text-xs mt-1">(亚洲时区)</p>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-20 px-4 bg-[#f5f0e8]">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-[#1a2a1a] text-center mb-12">常见问题</h2>
      <div class="space-y-4">
        <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100">
          <h3 class="font-bold text-[#1a2a1a]">📦 如何购买？</h3>
          <p class="text-gray-500 text-sm mt-2">可以在电商平台aliexpress,amazon,temu里面搜索dotwise 这样就可以看到我们的产品 我们会陆续上架产品。</p>
        </div>
        <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100">
          <h3 class="font-bold text-[#1a2a1a]">dotwise品牌下的所有灯都可以用app控制吗？</h3>
          <p class="text-gray-500 text-sm mt-2">目前只有部分型号支持手机蓝牙app控制：E3500，E3MINI PRO。</p>
        </div>
        <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100">
          <h3 class="font-bold text-[#1a2a1a]">🔄 可以退换货吗？</h3>
          <p class="text-gray-500 text-sm mt-2">详情请查看每个商品的退换货政策。</p>
        </div>
        <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100">
          <h3 class="font-bold text-[#1a2a1a]">🔄 可以退换货吗？</h3>
          <p class="text-gray-500 text-sm mt-2">详情请查看每个商品的退换货政策。</p></div>
        <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100">
          <h3 class="font-bold text-[#1a2a1a]">露营灯控制App 在哪里下载？</h3>
          <p class="text-gray-500 text-sm mt-2">智能露营灯 App 即将在 Google Play 和 App Store 上线，敬请期待。</p>
        </div>
        <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100">
          <h3 class="font-bold text-[#1a2a1a]">🌏 送货到哪些国家？</h3>
          <p class="text-gray-500 text-sm mt-2">我们可以寄送到全球大部分国家和地区。</p>
        </div>
      </div>
    </div>
  </section>

</Layout>