---
// src/pages/e3500.astro
import Layout from '../components/Layout.astro';
---

<Layout title="dotwise E3500 智能露营灯 — 2700K-6500K 无极调光 · App智控">

    <!-- ============================================================ -->
    <!-- Hero 区域 -->
    <!-- ============================================================ -->
    <header class="hero-gradient pt-28 min-h-screen flex items-center relative overflow-hidden">
        <div class="absolute inset-0 opacity-5" style="background-image: url('data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSI2MCIgaGVpZ2h0PSI2MCIgdmlld0JveD0iMCAwIDYwIDYwIj48cGF0aCBkPSJNMzAgNWwxMC4zIDUuN2wxMC4zIDUuN3YxMS4zbC0xMC4zIDUuN0wzMCAzNWwtMTAuMy01LjdMOS4zIDE3LjdWNi40TDE5LjcgNS43IDMwIDV6IiBmaWxsPSIjZmZmIiBvcGFjaXR5PSIwLjA1Ii8+PC9zdmc+'); background-size: 60px 60px;"></div>

        <div class="max-w-7xl mx-auto px-4 sm:px-6 relative z-10 py-16">
            <div class="grid lg:grid-cols-2 gap-12 items-center">

                <!-- 左侧文案 -->
                <div>
                    <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm text-white/90 text-xs sm:text-sm px-4 py-1.5 rounded-full mb-6 tracking-wide">
                        <span class="w-2 h-2 bg-[#c9a96e] rounded-full animate-pulse"></span>
                        NEW · 2026 Collection
                    </div>

                    <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold text-white leading-[1.1] tracking-tight">
                        E3500
                        <span class="block text-[#e8d5b5] mt-1">智能露营灯</span>
                    </h1>

                    <p class="text-white/75 text-lg md:text-xl max-w-lg mt-6 leading-relaxed">
                        2700K–6500K 无极调色温 · App 蓝牙本地智控 · 100h+ 超长续航 · IP54 全天候防护。<br />
                        不是照亮黑暗，而是雕刻氛围。
                    </p>

                    <div class="flex flex-wrap gap-3 mt-8">
                        <span class="bg-white/10 backdrop-blur-sm text-white/90 text-sm px-4 py-2 rounded-full border border-white/10">🎨 无极调色温</span>
                        <span class="bg-white/10 backdrop-blur-sm text-white/90 text-sm px-4 py-2 rounded-full border border-white/10">📱 App 智控</span>
                        <span class="bg-white/10 backdrop-blur-sm text-white/90 text-sm px-4 py-2 rounded-full border border-white/10">⏱️ 100h+ 续航</span>
                        <span class="bg-white/10 backdrop-blur-sm text-white/90 text-sm px-4 py-2 rounded-full border border-white/10">💧 IP54 防水</span>
                    </div>

                    <div class="flex flex-wrap gap-4 mt-10">
                        <a href="#buy" class="bg-[#e8d5b5] hover:bg-[#dcc6a3] text-[#1a2a1a] px-8 py-3.5 rounded-full font-semibold transition shadow-lg flex items-center gap-2">
                            🛍️ 立即购买 ¥399
                        </a>
                        <a href="#specs" class="border border-white/30 hover:bg-white/10 text-white px-8 py-3.5 rounded-full font-semibold transition flex items-center gap-2">
                            📋 查看规格
                        </a>
                    </div>
                </div>

                <!-- 右侧产品图 -->
                <div class="relative flex justify-center lg:justify-end">
                    <div class="relative w-full max-w-sm lg:max-w-md">
                        <div class="aspect-square bg-gradient-to-br from-[#e8d5b5]/20 to-[#2d5a27]/20 rounded-3xl border border-white/10 backdrop-blur-sm flex items-center justify-center overflow-hidden">
                            <img src="https://img.dotwise.top/1549.jpg" alt="dotwise E3500 智能露营灯" class="w-full h-full object-cover rounded-3xl" />
                        </div>
                        <div class="absolute -bottom-4 -right-4 bg-white/10 backdrop-blur-md rounded-2xl px-5 py-3 border border-white/10 text-white text-sm font-medium">
                            <span class="text-[#e8d5b5]">✦</span> 2700K–6500K
                        </div>
                        <div class="absolute -top-4 -left-4 bg-[#e8d5b5]/20 backdrop-blur-md rounded-2xl px-5 py-3 border border-white/10 text-white/90 text-sm font-medium">
                            <span class="text-[#e8d5b5]">⚡</span> 100h+ Runtime
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </header>

    <!-- ============================================================ -->
    <!-- 核心卖点 -->
    <!-- ============================================================ -->
    <section class="py-20 px-4 max-w-7xl mx-auto">
        <div class="text-center mb-16">
            <span class="inline-block bg-[#2d5a27]/10 text-[#2d5a27] text-xs font-semibold px-4 py-1 rounded-full tracking-wider uppercase mb-3">Why E3500</span>
            <h2 class="text-3xl sm:text-4xl font-bold text-[#1a2a1a]">每一处细节，都为真实露营场景而生</h2>
            <p class="text-gray-500 mt-3 max-w-xl mx-auto">从黄昏到黎明，E3500 让每一刻露营时光都恰到好处。</p>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
            <div class="bg-white rounded-2xl p-8 border border-gray-100 hover:shadow-lg transition text-center">
                <div class="text-4xl mb-4">🎨</div>
                <h3 class="text-xl font-bold text-[#1a2a1a]">无极调色温</h3>
                <p class="text-gray-500 text-sm mt-2 leading-relaxed">2700K 暖黄烛光到 6500K 冷白工作光连续可调，精准匹配阅读、烹饪、社交、观星等每一个场景需求。</p>
            </div>
            <div class="bg-white rounded-2xl p-8 border border-gray-100 hover:shadow-lg transition text-center">
                <div class="text-4xl mb-4">📱</div>
                <h3 class="text-xl font-bold text-[#1a2a1a]">App 蓝牙本地智控</h3>
                <p class="text-gray-500 text-sm mt-2 leading-relaxed">100% 本地蓝牙直连，无需网络、无需注册账号。支持多灯组网同步、定时开关、呼吸模式，隐私零风险。</p>
            </div>
            <div class="bg-white rounded-2xl p-8 border border-gray-100 hover:shadow-lg transition text-center">
                <div class="text-4xl mb-4">🔋</div>
                <h3 class="text-xl font-bold text-[#1a2a1a]">100h+ 超长续航</h3>
                <p class="text-gray-500 text-sm mt-2 leading-relaxed">内置 20000mAh 电池，低亮模式续航超 3 天。Type-C 快充 4 小时满电，支持充电宝边充边用。</p>
            </div>
            <div class="bg-white rounded-2xl p-8 border border-gray-100 hover:shadow-lg transition text-center">
                <div class="text-4xl mb-4">💧</div>
                <h3 class="text-xl font-bold text-[#1a2a1a]">IP54 全天候防护</h3>
                <p class="text-gray-500 text-sm mt-2 leading-relaxed">暴雨、沙尘、泼溅无忧，-20°C~50°C 宽温域稳定工作。从高山到海边，从容应对各种极端环境。</p>
            </div>
            <div class="bg-white rounded-2xl p-8 border border-gray-100 hover:shadow-lg transition text-center">
                <div class="text-4xl mb-4">🪶</div>
                <h3 class="text-xl font-bold text-[#1a2a1a]">轻量化便携</h3>
                <p class="text-gray-500 text-sm mt-2 leading-relaxed">仅重 650g，自带磁吸底座 + 挂扣。帐篷顶、车顶、桌面随心固定，收纳不占空间。</p>
            </div>
            <div class="bg-white rounded-2xl p-8 border border-gray-100 hover:shadow-lg transition text-center">
                <div class="text-4xl mb-4">🎵</div>
                <h3 class="text-xl font-bold text-[#1a2a1a]">呼吸式灯光</h3>
                <p class="text-gray-500 text-sm mt-2 leading-relaxed">灯光随呼吸变幻，多灯组网联动，一键打造沉浸式营地派对氛围。</p>
            </div>
        </div>
    </section>

    <!-- ============================================================ -->
    <!-- 场景展示 -->
    <!-- ============================================================ -->
    <section class="py-20 px-4 bg-[#f5f0e8]">
        <div class="max-w-7xl mx-auto">
            <div class="text-center mb-16">
                <span class="inline-block bg-[#2d5a27]/10 text-[#2d5a27] text-xs font-semibold px-4 py-1 rounded-full tracking-wider uppercase mb-3">Scenes</span>
                <h2 class="text-3xl sm:text-4xl font-bold text-[#1a2a1a]">为每个营地时刻而设计</h2>
                <p class="text-gray-500 mt-3 max-w-xl mx-auto">一盏灯，千种氛围</p>
            </div>
            <div class="grid md:grid-cols-2 gap-6">
                <div class="scene-card bg-white rounded-3xl overflow-hidden shadow-sm border border-gray-100">
                    <div class="aspect-[4/3] bg-gradient-to-br from-amber-100/40 to-[#2d5a27]/10 flex items-center justify-center">
                        <span class="text-6xl">🌅</span>
                    </div>
                    <div class="p-6">
                        <h3 class="text-xl font-bold text-[#1a2a1a]">黄昏 · 社交时刻</h3>
                        <p class="text-gray-500 text-sm mt-1">2700K 暖光 + 篝火模式，柔和光线模拟自然火光跳动，让围坐的每一刻都温暖惬意。</p>
                    </div>
                </div>
                <div class="scene-card bg-white rounded-3xl overflow-hidden shadow-sm border border-gray-100">
                    <div class="aspect-[4/3] bg-gradient-to-br from-blue-100/40 to-[#2d5a27]/10 flex items-center justify-center">
                        <span class="text-6xl">📖</span>
                    </div>
                    <div class="p-6">
                        <h3 class="text-xl font-bold text-[#1a2a1a]">深夜 · 阅读时光</h3>
                        <p class="text-gray-500 text-sm mt-1">4000K 中性光护眼照明，App 设定渐暗关机伴你入眠，不打扰帐篷里的宁静。</p>
                    </div>
                </div>
                <div class="scene-card bg-white rounded-3xl overflow-hidden shadow-sm border border-gray-100">
                    <div class="aspect-[4/3] bg-gradient-to-br from-slate-200/40 to-[#2d5a27]/10 flex items-center justify-center">
                        <span class="text-6xl">⛈️</span>
                    </div>
                    <div class="p-6">
                        <h3 class="text-xl font-bold text-[#1a2a1a]">突发 · 恶劣天气</h3>
                        <p class="text-gray-500 text-sm mt-1">IP54 防护从容应对暴雨，6500K 高亮穿透雨幕保障安全，极端环境依然可靠。</p>
                    </div>
                </div>
                <div class="scene-card bg-white rounded-3xl overflow-hidden shadow-sm border border-gray-100">
                    <div class="aspect-[4/3] bg-gradient-to-br from-purple-100/40 to-[#2d5a27]/10 flex items-center justify-center">
                        <span class="text-6xl">🎵</span>
                    </div>
                    <div class="p-6">
                        <h3 class="text-xl font-bold text-[#1a2a1a]">营地 · 派对模式</h3>
                        <p class="text-gray-500 text-sm mt-1">灯光随呼吸节奏变幻，多灯组网联动，一键打造沉浸式营地狂欢氛围。</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ============================================================ -->
    <!-- 规格参数 -->
    <!-- ============================================================ -->
    <section id="specs" class="py-20 px-4 max-w-6xl mx-auto">
        <div class="text-center mb-16">
            <span class="inline-block bg-[#2d5a27]/10 text-[#2d5a27] text-xs font-semibold px-4 py-1 rounded-full tracking-wider uppercase mb-3">Specifications</span>
            <h2 class="text-3xl sm:text-4xl font-bold text-[#1a2a1a]">技术规格</h2>
            <p class="text-gray-500 mt-3">E3500 详细参数一览</p>
        </div>

        <div class="bg-white rounded-3xl shadow-sm border border-gray-100 overflow-hidden">
            <div class="grid md:grid-cols-2 gap-0 divide-y md:divide-y-0 md:divide-x divide-gray-100">
                <div class="p-8">
                    <div class="space-y-4">
                        <div class="flex justify-between border-b border-gray-50 pb-3">
                            <span class="text-gray-500 text-sm font-medium">型号</span>
                            <span class="text-[#1a2a1a] font-semibold">E3500</span>
                        </div>
                        <div class="flex justify-between border-b border-gray-50 pb-3">
                            <span class="text-gray-500 text-sm font-medium">色温范围</span>
                            <span class="text-[#1a2a1a] font-semibold">2700K – 6500K 无极调节</span>
                        </div>
                        <div class="flex justify-between border-b border-gray-50 pb-3">
                            <span class="text-gray-500 text-sm font-medium">最大亮度</span>
                            <span class="text-[#1a2a1a] font-semibold">3500 流明</span>
                        </div>
                        <div class="flex justify-between border-b border-gray-50 pb-3">
                            <span class="text-gray-500 text-sm font-medium">电池容量</span>
                            <span class="text-[#1a2a1a] font-semibold">20000mAh (3.7V)</span>
                        </div>
                        <div class="flex justify-between border-b border-gray-50 pb-3">
                            <span class="text-gray-500 text-sm font-medium">续航时间</span>
                            <span class="text-[#1a2a1a] font-semibold">高亮 8h / 中亮 40h / 低亮 100h+</span>
                        </div>
                        <div class="flex justify-between border-b border-gray-50 pb-3">
                            <span class="text-gray-500 text-sm font-medium">充电接口</span>
                            <span class="text-[#1a2a1a] font-semibold">USB-C (5V/2A)</span>
                        </div>
                        <div class="flex justify-between">
                            <span class="text-gray-500 text-sm font-medium">防水等级</span>
                            <span class="text-[#1a2a1a] font-semibold">IP54</span>
                        </div>
                    </div>
                </div>
                <div class="p-8">
                    <div class="space-y-4">
                        <div class="flex justify-between border-b border-gray-50 pb-3">
                            <span class="text-gray-500 text-sm font-medium">重量</span>
                            <span class="text-[#1a2a1a] font-semibold">650g</span>
                        </div>
                        <div class="flex justify-between border-b border-gray-50 pb-3">
                            <span class="text-gray-500 text-sm font-medium">尺寸</span>
                            <span class="text-[#1a2a1a] font-semibold">294 × 84 × 50 mm</span>
                        </div>
                        <div class="flex justify-between border-b border-gray-50 pb-3">
                            <span class="text-gray-500 text-sm font-medium">连接方式</span>
                            <span class="text-[#1a2a1a] font-semibold">Bluetooth 5.2 (本地直连)</span>
                        </div>
                        <div class="flex justify-between border-b border-gray-50 pb-3">
                            <span class="text-gray-500 text-sm font-medium">材质</span>
                            <span class="text-[#1a2a1a] font-semibold">ABS + PC</span>
                        </div>
                        <div class="flex justify-between border-b border-gray-50 pb-3">
                            <span class="text-gray-500 text-sm font-medium">工作温度</span>
                            <span class="text-[#1a2a1a] font-semibold">-20°C ~ 50°C</span>
                        </div>
                        <div class="flex justify-between">
                            <span class="text-gray-500 text-sm font-medium">包装清单</span>
                            <span class="text-[#1a2a1a] font-semibold text-right">灯体 ×1、Type-C 线 ×1<br>磁吸扣 ×1、挂钩 ×1</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ============================================================ -->
    <!-- FAQ -->
    <!-- ============================================================ -->
    <section class="py-20 px-4 bg-[#f5f0e8]">
        <div class="max-w-4xl mx-auto">
            <div class="text-center mb-16">
                <span class="inline-block bg-[#2d5a27]/10 text-[#2d5a27] text-xs font-semibold px-4 py-1 rounded-full tracking-wider uppercase mb-3">FAQ</span>
                <h2 class="text-3xl sm:text-4xl font-bold text-[#1a2a1a]">常见问题</h2>
            </div>
            <div class="space-y-4">
                <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100">
                    <h3 class="font-bold text-[#1a2a1a] flex items-center gap-2">📱 App 需要联网或注册账号吗？</h3>
                    <p class="text-gray-500 text-sm mt-2">完全不需要。E3500 采用纯本地蓝牙直连，打开 App 即自动配对，无网络环境下所有功能正常使用，隐私零风险。</p>
                </div>
                <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100">
                    <h3 class="font-bold text-[#1a2a1a] flex items-center gap-2">🔗 可以同时控制多盏灯吗？</h3>
                    <p class="text-gray-500 text-sm mt-2">可以。App 支持最多 100 盏灯同时控制，也可单独控制每一盏，组网联动自由度更高。</p>
                </div>
                <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100">
                    <h3 class="font-bold text-[#1a2a1a] flex items-center gap-2">🔋 能用充电宝边充边用吗？</h3>
                    <p class="text-gray-500 text-sm mt-2">支持。Type-C 接口兼容主流充电宝，边充边用不降亮度，户外长时间使用无焦虑。</p>
                </div>
                <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100">
                    <h3 class="font-bold text-[#1a2a1a] flex items-center gap-2">🧲 磁吸底座会刮伤车漆/帐篷吗？</h3>
                    <p class="text-gray-500 text-sm mt-2">不会。底座包裹食品级硅胶防滑垫，吸附牢固且不留痕，也可搭配挂钩悬挂使用。</p>
                </div>
            </div>
        </div>
    </section>

    <!-- ============================================================ -->
    <!-- CTA -->
    <!-- ============================================================ -->
    <section id="buy" class="py-20 px-4 bg-[#1a2a1a] text-white text-center">
        <div class="max-w-3xl mx-auto">
            <h2 class="text-3xl sm:text-4xl font-bold">立即拥有你的智慧光源</h2>
            <p class="text-white/70 text-lg mt-4">E3500 智能露营灯 · ¥399</p>
            <a href="#" class="inline-block bg-[#e8d5b5] hover:bg-[#dcc6a3] text-[#1a2a1a] px-12 py-4 rounded-full font-semibold text-lg transition shadow-lg mt-8">
                🛍️ 立即购买
            </a>
            <div class="flex flex-wrap justify-center gap-6 mt-8 text-sm text-white/50">
                <span>✅ 30天无理由退换</span>
                <span>✅ 1年质保</span>
                <span>✅ 顺丰包邮</span>
            </div>
        </div>
    </section>

</Layout>