        <li><a href="/support" class="hover:text-white transition">FAQ</a></li>
        <li><a href="/privacy" class="hover:text-white transition">Privacy Policy</a></li>
        <li><a href="mailto:support@dotwise.top" class="hover:text-white transition">Contact Us</a></li>
      </ul>
    </div>

    <div>
      <h4 class="text-white font-semibold text-sm mb-3">Connect</h4>
      <p class="text-sm">📧 support@dotwise.top</p>
      <p class="text-sm text-white/30 mt-2">Mon–Fri, 9:00–18:00 (Asia)</p>
      <div class="flex flex-wrap gap-2 mt-3 text-xs text-white/30">
        <span>EN</span> · <span>中文</span> · <span>日本語</span> · <span>한국어</span>
