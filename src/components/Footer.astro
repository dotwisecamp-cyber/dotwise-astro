// src/components/Footer.astro
---

<footer class="bg-[#0f1a0f] text-white/60 py-12 px-4">
  <div class="max-w-7xl mx-auto grid sm:grid-cols-2 lg:grid-cols-4 gap-8">

    <div>
      <span class="text-xl font-bold text-white">⛺ dotwise</span>
      <p class="text-sm mt-2 text-white/40">Premium Camping Gear</p>
      <p class="text-sm text-white/30">Est. 2026 · Asia & Global</p>
      <div class="flex gap-3 mt-4 text-xl">
        <a href="#" class="hover:text-white transition">📱</a>
        <a href="#" class="hover:text-white transition">📷</a>
        <a href="#" class="hover:text-white transition">▶️</a>
      </div>
    </div>

    <div>
      <h4 class="text-white font-semibold text-sm mb-3">Products</h4>
      <ul class="space-y-2 text-sm">
        <li><a href="/g3" class="hover:text-white transition">G3 RGB Lantern</a></li>
        <li><a href="/e3500" class="hover:text-white transition">E3500 Smart Lantern</a></li>
        <li><a href="/lantern" class="hover:text-white transition">Classic Lanterns</a></li>
