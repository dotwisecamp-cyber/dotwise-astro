---
// src/components/Navigation.astro
---

<nav class="fixed top-0 left-0 right-0 bg-white/95 backdrop-blur-md z-50 shadow-sm border-b border-gray-100/80">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <div class="flex items-center justify-between h-16 md:h-20">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 shrink-0">
        <span class="text-2xl font-bold text-[#2d5a27] tracking-tight">⛺ dotwise</span>
        <span class="hidden md:inline text-xs text-gray-400 font-light tracking-widest uppercase border-l border-gray-300 pl-3">premium camping</span>
      </a>

      <!-- 导航链接 (桌面) -->
      <div class="hidden lg:flex items-center gap-8 text-sm font-medium text-gray-600">

        <!-- Products 下拉菜单 -->
        <div class="products-group relative">
          <a href="/products" class="hover:text-[#2d5a27] transition flex items-center gap-1">
            Products
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </a>
          <div class="products-dropdown absolute left-0 mt-2 w-56 bg-white rounded-2xl shadow-2xl border border-gray-100 p-2 z-50">
            <a href="/g3" class="flex items-center gap-3 px-3 py-2.5 rounded-xl hover:bg-gray-50 transition group">
              <div>
                <div class="text-sm font-semibold text-gray-800 group-hover:text-[#2d5a27]">G3 RGB Lantern</div>
                <div class="text-xs text-gray-400">Multi-Use LED · 8 Colors</div>
              </div>
              <span class="ml-auto text-[10px] bg-[#2d5a27]/10 text-[#2d5a27] px-2 py-0.5 rounded-full font-semibold">NEW</span>
            </a>
            <a href="/e3500" class="flex items-center gap-3 px-3 py-2.5 rounded-xl hover:bg-gray-50 transition group">
              <div>
                <div class="text-sm font-semibold text-gray-800 group-hover:text-[#2d5a27]">E3500 app control</div>
                <div class="text-xs text-gray-400">App-Enabled · 100h Runtime</div>
              </div>
              <span class="ml-auto text-[10px] bg-[#2d5a27]/10 text-[#2d5a27] px-2 py-0.5 rounded-full font-semibold">HOT</span>
            </a>
            <div class="border-t border-gray-100 my-1"></div>
            <a href="/lantern" class="flex items-center gap-3 px-3 py-2.5 rounded-xl hover:bg-gray-50 transition group">
              <div>
                <div class="text-sm font-semibold text-gray-800 group-hover:text-[#2d5a27]">Classic Lanterns</div>
                <div class="text-xs text-gray-400">Traditional · String Lights</div>
              </div>
            </a>
            <a href="/inflatable" class="flex items-center gap-3 px-3 py-2.5 rounded-xl hover:bg-gray-50 transition group">
              <div>
                <div class="text-sm font-semibold text-gray-800 group-hover:text-[#2d5a27]">inflatable</div>
                <div class="text-xs text-gray-400">2-in-1 · Portable</div>
              </div>
            </a>
            <a href="/igt-table" class="flex items-center gap-3 px-3 py-2.5 rounded-xl hover:bg-gray-50 transition group">
              <div>
                <div class="text-sm font-semibold text-gray-800 group-hover:text-[#2d5a27]">IGT Tables & accessories</div>
                <div class="text-xs text-gray-400">Modular · Accessories</div>
              </div>
            </a>
          </div>
        </div>

        <!-- 其他导航链接 -->
        <a href="/about" class="hover:text-[#2d5a27] transition">About</a>
        <a href="/community" class="hover:text-[#2d5a27] transition">Community</a>
        <a href="/support" class="hover:text-[#2d5a27] transition">Support</a>
      </div>

      <!-- 右侧：语言切换 + CTA -->
      <div class="flex items-center gap-3">

        <!-- 语言切换 (9种) -->
        <div class="lang-group relative">
          <button class="flex items-center gap-1.5 px-3 py-2 rounded-lg hover:bg-gray-50 transition text-sm font-medium text-gray-700">
            <span class="text-base">🌐</span>
            <span id="current-lang-label">EN</span>
            <svg class="w-3.5 h-3.5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </button>
          <div class="lang-dropdown absolute right-0 mt-2 w-56 bg-white rounded-2xl shadow-2xl border border-gray-100 p-2 z-50">
            <div class="grid grid-cols-3 gap-1">
              <a href="/en/" class="px-2.5 py-2 rounded-lg hover:bg-gray-50 text-xs font-medium text-gray-700 text-center transition">🇬🇧 EN</a>
              <a href="/zh/" class="px-2.5 py-2 rounded-lg hover:bg-gray-50 text-xs text-gray-600 text-center transition">🇨🇳 中文</a>
              <a href="/ja/" class="px-2.5 py-2 rounded-lg hover:bg-gray-50 text-xs text-gray-600 text-center transition">🇯🇵 日本語</a>
              <a href="/ko/" class="px-2.5 py-2 rounded-lg hover:bg-gray-50 text-xs text-gray-600 text-center transition">🇰🇷 한국어</a>
              <a href="/es/" class="px-2.5 py-2 rounded-lg hover:bg-gray-50 text-xs text-gray-600 text-center transition">🇪🇸 ES</a>
              <a href="/fr/" class="px-2.5 py-2 rounded-lg hover:bg-gray-50 text-xs text-gray-600 text-center transition">🇫🇷 FR</a>
              <a href="/de/" class="px-2.5 py-2 rounded-lg hover:bg-gray-50 text-xs text-gray-600 text-center transition">🇩🇪 DE</a>
              <a href="/it/" class="px-2.5 py-2 rounded-lg hover:bg-gray-50 text-xs text-gray-600 text-center transition">🇮🇹 IT</a>
              <a href="/ru/" class="px-2.5 py-2 rounded-lg hover:bg-gray-50 text-xs text-gray-600 text-center transition">🇷🇺 RU</a>
            </div>
          </div>
        </div>

        <!-- CTA 按钮 -->
        <a href="/lantern#app-download" class="hidden sm:inline-block bg-[#2d5a27] hover:bg-[#1f401a] text-white text-sm font-semibold px-5 py-2 rounded-full transition shadow-sm">
          📱 Download App
        </a>

        <!-- 移动端菜单按钮 -->
        <button class="lg:hidden p-2 text-gray-600 hover:text-[#2d5a27]">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
      </div>

    </div>
  </div>
</nav>

<!-- 下拉菜单样式 -->
<style is:global>
  .products-dropdown {
    opacity: 0;
    visibility: hidden;
    transform: translateY(-8px);
    transition: all 0.2s ease;
  }
  .products-group:hover .products-dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }
  .lang-dropdown {
    opacity: 0;
    visibility: hidden;
    transform: translateY(-8px);
    transition: all 0.2s ease;
  }
  .lang-group:hover .lang-dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }
</style>