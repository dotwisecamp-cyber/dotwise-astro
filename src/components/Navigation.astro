---
// src/components/Navigation.astro
---

<nav class="fixed top-0 left-0 right-0 bg-white/95 backdrop-blur-md z-50 shadow-sm border-b border-gray-100/80" id="main-nav">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <div class="flex items-center justify-between h-16 md:h-20">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 shrink-0">
        <span class="text-2xl font-bold text-[#2d5a27] tracking-tight">⛺ dotwise</span>
        <span class="hidden md:inline text-xs text-gray-400 font-light tracking-widest uppercase border-l border-gray-300 pl-3">premium camping</span>
      </a>

      <!-- 桌面导航 -->
      <div class="hidden lg:flex items-center gap-8 text-sm font-medium text-gray-600">

        <!-- Products 下拉 -->
        <div class="relative group">
          <button class="flex items-center gap-1 hover:text-[#2d5a27] transition cursor-pointer" id="desktop-products-btn">
            Products
            <svg class="w-3.5 h-3.5 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </button>
          <div class="absolute left-0 mt-2 w-56 bg-white rounded-2xl shadow-2xl border border-gray-100 p-2 z-50 opacity-0 invisible translate-y-[-8px] group-hover:opacity-100 group-hover:visible group-hover:translate-y-0 transition-all duration-200">
            <a href="/g3" class="flex items-center gap-3 px-3 py-2.5 rounded-xl hover:bg-gray-50 transition group/item">
              <div>
                <div class="text-sm font-semibold text-gray-800 group-hover/item:text-[#2d5a27]">G3 RGB Lantern</div>
                <div class="text-xs text-gray-400">Multi-Use LED · 8 Colors</div>
              </div>
              <span class="ml-auto text-[10px] bg-[#2d5a27]/10 text-[#2d5a27] px-2 py-0.5 rounded-full font-semibold">NEW</span>
            </a>
            <a href="/e3500" class="flex items-center gap-3 px-3 py-2.5 rounded-xl hover:bg-gray-50 transition group/item">
              <div>
                <div class="text-sm font-semibold text-gray-800 group-hover/item:text-[#2d5a27]">E3500 app control</div>
                <div class="text-xs text-gray-400">App-Enabled · 100h Runtime</div>
              </div>
              <span class="ml-auto text-[10px] bg-[#2d5a27]/10 text-[#2d5a27] px-2 py-0.5 rounded-full font-semibold">HOT</span>
            </a>
            <div class="border-t border-gray-100 my-1"></div>
            <a href="/lantern" class="flex items-center gap-3 px-3 py-2.5 rounded-xl hover:bg-gray-50 transition group/item">
              <div>
                <div class="text-sm font-semibold text-gray-800 group-hover/item:text-[#2d5a27]">Classic Lanterns</div>
                <div class="text-xs text-gray-400">Traditional · String Lights</div>
              </div>
            </a>
            <a href="/inflatable" class="flex items-center gap-3 px-3 py-2.5 rounded-xl hover:bg-gray-50 transition group/item">
              <div>
                <div class="text-sm font-semibold text-gray-800 group-hover/item:text-[#2d5a27]">Inflatable</div>
                <div class="text-xs text-gray-400">2-in-1 · Portable</div>
              </div>
            </a>
            <a href="/igt-table" class="flex items-center gap-3 px-3 py-2.5 rounded-xl hover:bg-gray-50 transition group/item">
              <div>
                <div class="text-sm font-semibold text-gray-800 group-hover/item:text-[#2d5a27]">IGT Tables & Accessories</div>
                <div class="text-xs text-gray-400">Modular · Accessories</div>
              </div>
            </a>
          </div>
        </div>

        <a href="/about" class="hover:text-[#2d5a27] transition">About</a>
        <a href="/community" class="hover:text-[#2d5a27] transition">Community</a>
        <a href="/support" class="hover:text-[#2d5a27] transition">Support</a>
      </div>

      <!-- 右侧区域 -->
      <div class="flex items-center gap-2 sm:gap-3">

        <!-- CTA 按钮 (桌面) -->
        <a href="/lantern#app-download" class="hidden sm:inline-block bg-[#2d5a27] hover:bg-[#1f401a] text-white text-xs sm:text-sm font-semibold px-3 sm:px-5 py-1.5 sm:py-2 rounded-full transition shadow-sm whitespace-nowrap">
          📱 Download App
        </a>

        <!-- 移动端菜单按钮 -->
        <button id="mobile-menu-btn" class="lg:hidden p-2 text-gray-600 hover:text-[#2d5a27] transition" aria-label="Toggle menu">
          <svg id="menu-icon-open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
          <svg id="menu-icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
      </div>

    </div>
  </div>

  <!-- 移动端菜单面板 -->
  <div id="mobile-menu" class="lg:hidden hidden border-t border-gray-100 bg-white/98 backdrop-blur-md">
    <div class="px-4 py-4 space-y-1 max-h-[calc(100vh-4rem)] overflow-y-auto">

      <!-- Products 分组 -->
      <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider px-2 pt-2 pb-1">Products</p>
      <a href="/g3" class="flex items-center justify-between px-3 py-3 rounded-xl hover:bg-gray-50 transition">
        <span class="text-sm font-semibold text-gray-800">G3 RGB Lantern</span>
        <span class="text-[10px] bg-[#2d5a27]/10 text-[#2d5a27] px-2 py-0.5 rounded-full font-semibold">NEW</span>
      </a>
      <a href="/e3500" class="flex items-center justify-between px-3 py-3 rounded-xl hover:bg-gray-50 transition">
        <span class="text-sm font-semibold text-gray-800">E3500 App Control</span>
        <span class="text-[10px] bg-[#2d5a27]/10 text-[#2d5a27] px-2 py-0.5 rounded-full font-semibold">HOT</span>
      </a>
      <a href="/lantern" class="block px-3 py-3 rounded-xl hover:bg-gray-50 transition">
        <span class="text-sm font-semibold text-gray-800">Classic Lanterns</span>
      </a>
      <a href="/inflatable" class="block px-3 py-3 rounded-xl hover:bg-gray-50 transition">
        <span class="text-sm font-semibold text-gray-800">Inflatable</span>
      </a>
      <a href="/igt-table" class="block px-3 py-3 rounded-xl hover:bg-gray-50 transition">
        <span class="text-sm font-semibold text-gray-800">IGT Tables & Accessories</span>
      </a>

      <div class="border-t border-gray-100 my-2"></div>

      <a href="/about" class="block px-3 py-3 rounded-xl hover:bg-gray-50 transition text-sm font-semibold text-gray-800">About</a>
      <a href="/community" class="block px-3 py-3 rounded-xl hover:bg-gray-50 transition text-sm font-semibold text-gray-800">Community</a>
      <a href="/support" class="block px-3 py-3 rounded-xl hover:bg-gray-50 transition text-sm font-semibold text-gray-800">Support</a>

      <div class="border-t border-gray-100 my-2"></div>

      <!-- CTA -->
      <a href="/lantern#app-download" class="block text-center bg-[#2d5a27] hover:bg-[#1f401a] text-white text-sm font-semibold px-5 py-3 rounded-full transition shadow-sm mx-2">
        📱 Download App
      </a>
    </div>
  </div>
</nav>

<script>
  // Mobile menu toggle
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const openIcon = document.getElementById('menu-icon-open');
  const closeIcon = document.getElementById('menu-icon-close');

  if (menuBtn && mobileMenu) {
    menuBtn.addEventListener('click', () => {
      const isOpen = !mobileMenu.classList.contains('hidden');
      if (isOpen) {
        mobileMenu.classList.add('hidden');
        openIcon.classList.remove('hidden');
        closeIcon.classList.add('hidden');
        document.body.style.overflow = '';
      } else {
        mobileMenu.classList.remove('hidden');
        openIcon.classList.add('hidden');
        closeIcon.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
      }
    });

    // Close menu when clicking a link
    mobileMenu.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        mobileMenu.classList.add('hidden');
        openIcon.classList.remove('hidden');
        closeIcon.classList.add('hidden');
        document.body.style.overflow = '';
      });
    });
  }
</script>
